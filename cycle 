const visit = (node: NodeId, value: number, visited: Set<NodeId>) => {
  if (visited.has(node)) {
    throw new Error(`Cycle detected at ${node}`);
  }

  visited.add(node);

  const outgoing = this.graph.edges.filter(e => e.from === node);

  if (outgoing.length === 0) {
    result[node] = (result[node] || 0) + value;
    return;
  }

  for (const edge of outgoing) {
    visit(edge.to, value * edge.weight, new Set(visited));
  }
};